{
  "name": "odk-central-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "      nf start vite,nginx",
    "dev:build": "nf start build,nginx",
    "build": "turbo run build",
    "build:types": "npm-run-all 'build:types -w=@getodk/common' 'build:types -w=@getodk/xpath' 'build:types -w=@getodk/xforms-engine' 'build:types -w=@getodk/web-forms'",
    "build:web": "vite build",
    "changeset": "changeset",
    "eslint": "eslint bin/ e2e-tests/ *.js -c bin/eslint.config.js --cache --max-warnings 0",
    "lint": "npm-run-all -p eslint 'lint --workspaces'",
    "lint:fix": "npm run lint:fix --workspaces",
    "test": "npm run test --workspaces",
    "test:e2e": "e2e-tests/run-tests.sh",
    "version": "changeset version"
  },
  "volta": {
    "node": "24.16.0"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@sentry/vue": "10.55",
    "vue": "^3.5.29",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@transifex/cli": "^7.1.5",
    "@tsconfig/node20": "^20.1.8",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/browser-playwright": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "adm-zip": "^0.5.17",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "foreman": "^3.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": "^24.16.0",
    "npm": "11"
  }
}

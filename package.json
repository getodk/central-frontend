{
  "name": "odk-central-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "--dev": "          nf start vite,nginx-docker",
    "--dev-no-docker": "nf start vite,nginx-host",
    "--dev:build": "nf start build,nginx-docker",
    "--dev-no-docker:build": "nf start build,nginx-host",
    "--build": "vite build",
    "build": "turbo run build",
    "build:web": "vite build",
    "eslint": "npm run eslint --workspaces",
    "--lint": "npm run eslint && npm run transifex:lint",
    "--lint:fix": "npm run eslint:fix && npm run transifex:fix",
    "--test": "./apps/central/test/run.sh",
    "--test:e2e": "e2e-tests/run-tests.sh"
  },
  "volta": {
    "node": "24.13.0"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@transifex/cli": "^7.1.5",
    "@tsconfig/node20": "^20.1.8",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all2": "^8.0.4",
    "only-allow": "^1.2.1",
    "organize-imports-cli": "^0.10.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}

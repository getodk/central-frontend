{
  "name": "@getodk/central-frontend",
  "version": "2026.2.0",
  "private": true,
  "scripts": {
    "eslint": "eslint --max-warnings 0 --cache --ext .js,.vue src/ test/ bin/ *.js",
    "eslint:fix": "eslint --max-warnings 0 --fix --cache --ext .js,.vue src/ test/ bin/ *.js",
    "lint": "npm run eslint && npm run transifex:lint",
    "lint:fix": "npm run eslint:fix && npm run transifex:fix",
    "test": "./test/run.sh",
    "transifex:destructure": "node bin/transifex/destructure.js",
    "transifex:fix": "node bin/transifex/restructure.js > transifex/strings_en.json",
    "transifex:lint": "bash -c 'diff transifex/strings_en.json <(node bin/transifex/restructure.js)'"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.1.0",
    "axios": "^1.18.1",
    "bootstrap": "~3",
    "dompurify": "^3.4.11",
    "flatpickr": "~4.6",
    "jquery": "~3",
    "luxon": "~1",
    "marked": "~4",
    "ol": "^10.9.0",
    "pako": "~1.0",
    "papaparse": "^5.5.4",
    "qrcode-generator": "~1",
    "ramda": "~0.27",
    "vue": "^3.5.39",
    "vue-flatpickr-component": "~9",
    "vue-i18n": "^10.0.7",
    "vue-router": "^4.6.3",
    "xml-formatter": "~2"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.7.0",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/eslint-config-airbnb": "^7.0.0",
    "@vue/test-utils": "^2.4.11",
    "chai": "^5.1.1",
    "chai-as-promised": "^8.0.0",
    "comment-json": "~4",
    "eslint": "^8.28.0",
    "eslint-plugin-import": "~2",
    "eslint-plugin-vue": "~9",
    "jsqr": "^1.4.0",
    "karma": "~6",
    "karma-chrome-launcher": "~3",
    "karma-mocha": "~2.0",
    "karma-source-map-support": "^1.4.0",
    "karma-sourcemap-loader": "^0.4.0",
    "karma-spec-reporter": "^0.0.36",
    "karma-webpack": "^5.0.0",
    "mocha": "^10.1.0",
    "raw-loader": "^4.0.2",
    "sass": "~1",
    "sass-loader": "^13.2.0",
    "sinon": "~9",
    "util": "^0.12.5"

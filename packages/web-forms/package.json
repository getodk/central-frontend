{
  "name": "@getodk/web-forms",
  "version": "0.24.0",
  "license": "Apache-2.0",
  "description": "ODK Web Forms",
  "author": "getodk",
  "repository": {
    "type": "git",
    "url": "https://github.com/getodk/web-forms",
    "directory": "packages/web-forms"
  },
  "bugs": "https://github.com/getodk/web-forms/issues",
  "homepage": "https://getodk.org/",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "^24.16.0",
    "npm": "11"
  },
  "scripts": {
    "build": "npm-run-all -l build:clean build:translations build:demo build:js",
    "build:clean": "rimraf dist/ dist-demo/",
    "build:demo": "vite build --mode demo --outDir dist-demo",
    "build:js": "vite build",
    "build:translations": "node bin/merge-translations.js",
    "translations:pull": "cd ../.. && tx pull -r web_forms.strings -a -f --mode translator",
    "translations:push": "cd ../.. && tx push -r web_forms.strings -s",
    "dev": "vite",
    "dist-demo": "npm run build && vite serve dist-demo --port 5174",
    "feature-matrix": "node bin/feature-matrix/render.js",
    "format:fix": "npm-run-all --print-name format:vue format:prettier",
    "format:lint": "prettier -c \"**/*\" --ignore-unknown --cache",
    "format:prettier": "prettier -w \"**/*\" --ignore-unknown --cache",
    "format:vue": "eslint ./**/*.vue  --report-unused-disable-directives --cache --fix",
    "lint": "eslint . --report-unused-disable-directives --cache --max-warnings 0 && npm run format:lint",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --cache --max-warnings 0 && npm run format:fix",
    "test": "npm-run-all -nl 'test:*'",
    "test:e2e:functional:all": "playwright test --project=functional-*",
    "test:e2e:functional:chromium": "playwright test --project=functional-chromium",
    "test:e2e:functional:firefox": "playwright test --project=functional-firefox",
    "test:e2e:functional:webkit": "playwright test --project=functional-webkit",
    "test:e2e:visual:chromium": "playwright test --project=visual-chromium",
    "test:e2e:visual:firefox": "playwright test --project=visual-firefox",
    "test:e2e:visual:webkit": "playwright test --project=visual-webkit",
    "test-node:jsdom": "vitest run",
    "test-browser:chromium": "BROWSER_NAME=chromium vitest run",
    "test-browser:firefox": "BROWSER_NAME=firefox vitest run",
    "test-browser:webkit": "BROWSER_NAME=webkit vitest run",
    "test-watch:jsdom": "vitest",
    "test-watch:chromium": "BROWSER_NAME=chromium vitest",
    "test-watch:firefox": "BROWSER_NAME=firefox vitest",
    "test-watch:webkit": "BROWSER_NAME=webkit vitest",
    "test:types": "npm-run-all -nl 'test:types:*'",
    "test:types:app": "vue-tsc --project ./tsconfig.app.json --emitDeclarationOnly false --noEmit",
    "test:types:node": "vue-tsc --project ./tsconfig.node.json --emitDeclarationOnly false --noEmit",
    "test:types:vitest": "vue-tsc --project ./tsconfig.vitest.json --emitDeclarationOnly false --noEmit"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/roboto": "^5.2.9",
    "@getodk/xforms-engine": "0.22.0",
    "@primeuix/themes": "1.0.3",
    "@types/image-blob-reduce": "^4",
    "@types/ramda": "^0.31.1",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "jsdom": "^27.2.0",
    "primeflex": "^4.0.0",
    "primevue": "4.3.3",
    "ramda": "^0.32.0",
    "sass": "^1.94.2",
    "typescript": "~5.9.3",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "peerDependencies": {
    "vue": "^3.5.29"
  },
  "dependencies": {
    "@formatjs/intl": "^4.1.4",
    "@mdi/js": "^7.4.47",
    "dompurify": "^3.3.0",
    "image-blob-reduce": "^4.1.0",
    "konva": "^10.2.5",
    "ol": "^10.7.0",
    "primelocale": "^2.3.1",
    "vue-draggable-plus": "^0.6.1",
    "vue-konva": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml"
        xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
        xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms"
        xmlns:odk="http://www.opendatakit.org/xforms">
  <h:head>
    <h:title>Draw, Annotate &amp; Signature</h:title>
    <model odk:xforms-version="1.0.0">
      <itext>
        <translation lang="English (en)">
          <text id="/data/signature:label">
            <value>Sign here</value>
          </text>
          <text id="/data/draw:label">
            <value>Draw something</value>
          </text>
          <text id="/data/annotate:label">
            <value>Annotate image</value>
          </text>
          <text id="/data/annotate_default:label">
            <value>Annotate with default image</value>
          </text>
          <text id="/data/annotate_disabled:label">
            <value>Annotate disabled (based on previous value)</value>
          </text>
        </translation>
        <translation lang="Spanish (es)">
          <text id="/data/signature:label">
            <value>Firme aquí</value>
          </text>
          <text id="/data/draw:label">
            <value>Dibuje algo</value>
          </text>
          <text id="/data/annotate:label">
            <value>Anotar imagen</value>
          </text>
          <text id="/data/annotate_default:label">
            <value>Anotar con imagen predeterminada</value>
          </text>
          <text id="/data/annotate_disabled:label">
            <value>Anotar deshabilitado (basado en valor anterior)</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data id="draw-annotation-signature" version="2026042801">
          <signature/>
          <draw/>
          <annotate/>
          <annotate_default>jr://images/default-image.png</annotate_default>
          <annotate_disabled/>
          <meta>
            <instanceID/>
          </meta>
        </data>
      </instance>

      <bind nodeset="/data/signature" type="binary"/>
      <bind nodeset="/data/draw" type="binary"/>
      <bind nodeset="/data/annotate" type="binary" orx:max-pixels="500"/>
      <bind nodeset="/data/annotate_default" type="binary"/>
      <bind nodeset="/data/annotate_disabled" type="binary" readonly=" /data/annotate = ''"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
    </model>
  </h:head>
  <h:body>
    <upload mediatype="image/*" ref="/data/signature" appearance="signature">
      <label ref="jr:itext('/data/signature:label')"/>
    </upload>

    <upload mediatype="image/*" ref="/data/draw" appearance="draw">
      <label ref="jr:itext('/data/draw:label')"/>
    </upload>

    <upload mediatype="image/*" ref="/data/annotate" appearance="annotate">
      <label ref="jr:itext('/data/annotate:label')"/>
    </upload>

    <upload mediatype="image/*" ref="/data/annotate_default" appearance="annotate">
      <label ref="jr:itext('/data/annotate_default:label')"/>
    </upload>

    <upload mediatype="image/*" ref="/data/annotate_disabled" appearance="annotate">
      <label ref="jr:itext('/data/annotate_disabled:label')"/>
    </upload>
  </h:body>
</h:html>
